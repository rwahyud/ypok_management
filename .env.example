# ========================================
# SUPABASE CREDENTIALS
# ========================================
# Copy file ini menjadi .env dan isi dengan credentials Anda

SUPABASE_HOST=db.xxxxxxxxxxxxxx.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your_secure_password_here

# ========================================
# SUPABASE PROJECT INFO
# ========================================
SUPABASE_PROJECT_URL=https://xxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# ========================================
# APPLICATION SETTINGS
# ========================================
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta

# ========================================
# CARA MENDAPATKAN CREDENTIALS
# ========================================
# 1. Buka: https://supabase.com/dashboard
# 2. Pilih project Anda atau buat project baru
# 3. Settings > Database > Connection String
#    - Copy Host, Password
# 4. Settings > API
#    - Copy Project URL
#    - Copy anon (public) key
#    - Copy service_role key (jangan di-commit!)
# 5. Save credentials ke file .env (jangan .env.example!)
