# Supabase PostgreSQL URL (recommended for Vercel)
# Example:
# DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Optional fallback if DATABASE_URL is not set
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_PASSWORD=

# App environment
APP_ENV=production

# PostgreSQL compatibility bootstrap for legacy MySQL SQL functions.
# 1 = auto-create compatibility functions on connection, 0 = disable.
PGSQL_AUTO_COMPAT=1

# Supabase Storage (for file uploads on Vercel serverless)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=ypok-files
