# Database driver: pgsql (Supabase) or mysql (local fallback)
DB_DRIVER=pgsql

# Option A: Direct DSN URL (recommended for Vercel)
# Example:
# DATABASE_URL=pgsql:host=aws-0-ap-southeast-1.pooler.supabase.com;port=6543;dbname=postgres;user=postgres.xxxxx;password=YOUR_PASSWORD;sslmode=require
DATABASE_URL=

# Option B: Separate DB parts
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_PASSWORD=

# App environment
APP_ENV=production

# PostgreSQL compatibility bootstrap for legacy MySQL SQL functions.
# 1 = auto-create compatibility functions on connection, 0 = disable.
PGSQL_AUTO_COMPAT=1
