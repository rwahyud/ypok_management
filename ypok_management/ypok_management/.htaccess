DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
</IfModule>

# Enable mod_expires for cache control
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Enable compression for text assets
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/css application/javascript text/javascript text/html text/plain
</IfModule>

# Leverage browser caching for static assets
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|png|jpg|jpeg|svg)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</IfModule>
